  });

  // Puntos de control mock (se obtendrían con useContractRead)
  const [checkpoints] = useState([
    { descripcion: "Cosecha manual", timestamp: "2026-05-02", operador: "0xOper...1A2B" },
    { descripcion: "Beneficio lavado", timestamp: "2026-05-05", operador: "0xOper...3C4D" },
    { descripcion: "Embarque", timestamp: "2026-05-10", operador: "0xOper...5E6F" },
  ]);

  // Estado del pago (simulado)
  const [pagado, setPagado] = useState(false);

  // ============ ACCIÓN DE PAGO SIMULADA ============
  /**
   * Simula la recepción de un pago confidencial vía x402.
   * En producción, se llamaría a useContractWrite para invocar
   * procesarPagoX402 del contrato PasaporteVerde.
   */
  const handleRecibirPago = () => {
    // TODO: Ejecutar writeContract de wagmi:
    // const { write } = useContractWrite({
    //   address: pasaporteVerdeAddress,
    //   abi: pasaporteVerdeABI,
    //   functionName: 'procesarPagoX402',
    //   args: [lote.tokenId, ethers.utils.parseEther('100')],
    // });
    // O mediante x402 HTTP hook.
    alert("✔ Pago confidencial simulado – transferConfidencial ejecutado (mock).");
    setPagado(true);
  };

  return (
    <div className="min-h-screen bg-gradient-to-b from-green-50 to-white p-6">
      <Navbar productorAddress={productorAddress} />

      <div className="max-w-7xl mx-auto mt-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Columna izquierda: Pasaporte NFT */}
        <div className="lg:col-span-1">
          <NFTPassportCard lote={lote} />
        </div>

        {/* Columna central: Historial de trazabilidad */}
        <div className="lg:col-span-1">
          <TimelineView checkpoints={checkpoints} />
        </div>

        {/* Columna derecha: Liquidación y pago */}
        <div className="lg:col-span-1">
          <PaymentAction
            pagado={pagado}
            onRecibirPago={handleRecibirPago}
