// ===================== SUBCOMPONENTES =====================

/** Barra superior con dirección del productor */
function Navbar({ productorAddress }: { productorAddress: string }) {
  return (
    <nav className="flex items-center justify-between bg-white shadow-sm p-4 rounded-xl">
      <h1 className="text-xl font-bold text-green-800">Radix Trace</h1>
      <div className="flex items-center gap-2">
        <span className="text-sm text-gray-600">Conectado:</span>
        <span className="text-sm font-mono bg-gray-100 px-3 py-1 rounded-full truncate max-w-[200px]">
          {productorAddress}
        </span>
      </div>
    </nav>
  );
}

/** Tarjeta del pasaporte digital (NFT) */
function NFTPassportCard({ lote }: { lote: any }) {
  return (
    <div className="bg-white rounded-2xl shadow-lg p-6 border border-green-200">
      <h2 className="text-lg font-semibold text-green-900 mb-2">🌱 Pasaporte Digital</h2>
      <div className="bg-gray-100 rounded-xl h-40 flex items-center justify-center mb-4">
        {/* TODO: Cargar imagen desde IPFS usando tokenURI */}
        <span className="text-gray-400">Imagen IPFS</span>
      </div>
      <p className="text-sm font-medium text-green-800">{lote.nombre}</p>
      <p className="text-xs text-gray-500 mt-1">Token ID: {lote.tokenId}</p>
      <p className="text-xs text-gray-500">Registrado: {lote.fechaRegistro}</p>
    </div>
  );
}

/** Línea de tiempo de los puntos de control */
function TimelineView({ checkpoints }: { checkpoints: any[] }) {
  return (
    <div className="bg-white rounded-2xl shadow-lg p-6 border border-blue-200">
      <h2 className="text-lg font-semibold text-blue-900 mb-4">📋 Historial de Trazabilidad</h2>
      <ol className="relative border-l border-blue-300 ml-4">
        {checkpoints.map((cp, idx) => (
          <li key={idx} className="mb-4 ml-6">
            <span className="absolute flex items-center justify-center w-6 h-6 bg-blue-100 rounded-full -left-3 ring-8 ring-white">
              <span className="text-blue-800 text-xs">●</span>
            </span>
            <p className="text-sm font-medium text-gray-800">{cp.descripcion}</p>
            <time className="text-xs text-gray-500">{cp.timestamp}</time>
            <p className="text-xs text-gray-400 font-mono truncate">Operador: {cp.operador}</p>
          </li>
        ))}
      </ol>
    </div>
  );
}

/** Panel de liquidación confidencial con botón simulado */
function PaymentAction({
  pagado,
  onRecibirPago,
}: {
  pagado: boolean;
  onRecibirPago: () => void;
}) {
  return (
    <div className="bg-white rounded-2xl shadow-lg p-6 border border-amber-200">
      <h2 className="text-lg font-semibold text-amber-900 mb-2">💰 Liquidación Confidencial</h2>
      <div className="inline-flex items-center gap-1 bg-purple-100 text-purple-800 text-xs px-2 py-1 rounded-full">
        🔒 eERC20 Privado
      </div>
      {pagado ? (
        <div className="mt-4 bg-green-50 p-3 rounded-xl text-sm text-green-700">
          ✔ Pago recibido – Los fondos confidenciales (eERC20) han sido transferidos.
        </div>
      ) : (
        <button
          onClick={onRecibirPago}
          className="mt-4 w-full bg-amber-500 hover:bg-amber-600 text-white font-medium py-2 px-4 rounded-xl transition-colors"
        >
          Recibir Pago Confidencial (Simular x402)
        </button>
      )}
      <p className="text-xs text-gray-400 mt-2">
        * En producción, esta acción será ejecutada automáticamente por el endpoint x402 o mediante firma de compra.
      </p>
    </div>
  );
}
